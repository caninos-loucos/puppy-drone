# CONFIG_MCUBOOT_SERIAL_DIRECT_IMAGE_UPLOAD is not set
CONFIG_BOOT_SERIAL_UNALIGNED_BUFFER_SIZE=64
CONFIG_BOOT_MAX_LINE_INPUT_LEN=128
CONFIG_BOOT_LINE_BUFS=8
CONFIG_BOOT_SERIAL_MAX_RECEIVE_SIZE=1024
# CONFIG_BOOT_ERASE_PROGRESSIVELY is not set
CONFIG_BOOT_MGMT_ECHO=y
# CONFIG_ENABLE_MGMT_PERUSER is not set

#
# Entrance methods
#
CONFIG_BOOT_SERIAL_ENTRANCE_GPIO=y
CONFIG_BOOT_SERIAL_DETECT_DELAY=0
CONFIG_BOOT_SERIAL_WAIT_FOR_DFU=y
CONFIG_BOOT_SERIAL_WAIT_FOR_DFU_TIMEOUT=2000
CONFIG_BOOT_SERIAL_NO_APPLICATION=y
# CONFIG_BOOT_SERIAL_PIN_RESET is not set
# end of Entrance methods

CONFIG_BOOT_SERIAL_IMG_GRP_HASH=y
# CONFIG_BOOT_SERIAL_IMG_GRP_IMAGE_STATE is not set
