/delete-node/ &flash0;

/ {
    chosen {
        mcuboot,ram-load-dev = &sram;
        zephyr,sram = &bootram;
    };
};

&spi0 {
    flash0: flash@0 {
        compatible = "jedec,spi-nor";
        reg = <0>;
        spi-max-frequency = <20000000>;
        size = <(((8) * 1024) * 1024)>;
        status = "okay";

        partitions {
            compatible = "fixed-partitions";
            #size-cells = <1>;
            #address-cells = <1>;

            boot_partition: partition@0 {
                reg = <0 0x20000>;
                label = "boot_partition";
                read-only;
            };

            slot0_partition: partition@20000 {
                reg = <0x20000 0x40000>;
                label = "slot0";
            };

            slot1_partition: partition@60000 {
                reg = <0x60000 0x40000>;
    label = "slot1";
            };
        };
    };
};
